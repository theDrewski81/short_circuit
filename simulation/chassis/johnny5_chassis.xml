<mujoco model="johnny5_chassis">
  <!-- GENERATED by build_mjcf.py from mechanical/freecad/params.csv -- do not edit by hand. -->
  <compiler angle="degree" autolimits="true"/>
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"/>

  <default>
    <geom condim="3" friction="1 0.01 0.0001"/>
    <joint damping="0"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.25 0.3" rgb2="0.28 0.33 0.4"
             width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="6 6" reflectance="0.1"/>
    <material name="trunk_mat" rgba="0.85 0.78 0.55 1"/>
    <material name="wheel_mat" rgba="0.12 0.12 0.14 1"/>
    <material name="caster_mat" rgba="0.3 0.3 0.35 1"/>
  </asset>

  <worldbody>
    <light name="top" pos="0 0 1.2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="grid" friction="1 0.01 0.0001"/>

    <body name="trunk" pos="0 0 0.02350">
      <freejoint name="root"/>
      <!-- explicit inertial overrides geom-derived inertia: real mass rides taller than the tub -->
      <inertial pos="0 0 0.08650" mass="1.1970"
                diaginertia="0.004621 0.005476 0.003633"/>
      <site name="imu" pos="0 0 0.08650" size="0.005" rgba="1 0 0 1"/>

      <!-- chassis tub: collision + visual proxy (chassis-only; no arms/head) -->
      <geom name="tub" type="box" material="trunk_mat"
            pos="0 0 0.02070"
            size="0.07500 0.05900 0.02620"/>

      <!-- rear trailing caster, modelled as a rigid low-friction support sphere -->
      <geom name="caster" type="sphere" material="caster_mat"
            pos="-0.12500 0 -0.00650" size="0.01700"
            friction="0.25 0.005 0.0001"/>

      <!-- four track-contact wheels (front + rear per side), driven in L/R pairs -->
      <body name="wheel_rl" pos="-0.06000 0.07500 0">
        <joint name="wheel_rl_joint" type="hinge" axis="0 1 0" damping="0.00969"/>
        <geom name="wheel_rl_geom" type="cylinder" material="wheel_mat" fromto="0 -0.01400 0 0 0.01400 0" size="0.02350" mass="0.0285" friction="1.2 0.02 0.0001"/>
      </body>
      <body name="wheel_fl" pos="0.06000 0.07500 0">
        <joint name="wheel_fl_joint" type="hinge" axis="0 1 0" damping="0.00969"/>
        <geom name="wheel_fl_geom" type="cylinder" material="wheel_mat" fromto="0 -0.01400 0 0 0.01400 0" size="0.02350" mass="0.0285" friction="1.2 0.02 0.0001"/>
      </body>
      <body name="wheel_rr" pos="-0.06000 -0.07500 0">
        <joint name="wheel_rr_joint" type="hinge" axis="0 1 0" damping="0.00969"/>
        <geom name="wheel_rr_geom" type="cylinder" material="wheel_mat" fromto="0 -0.01400 0 0 0.01400 0" size="0.02350" mass="0.0285" friction="1.2 0.02 0.0001"/>
      </body>
      <body name="wheel_fr" pos="0.06000 -0.07500 0">
        <joint name="wheel_fr_joint" type="hinge" axis="0 1 0" damping="0.00969"/>
        <geom name="wheel_fr_geom" type="cylinder" material="wheel_mat" fromto="0 -0.01400 0 0 0.01400 0" size="0.02350" mass="0.0285" friction="1.2 0.02 0.0001"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- ctrl in [-1,1] -> torque in [-stall/2, +stall/2] N*m per wheel; per side sums to stall -->
    <motor name="motor_rl" joint="wheel_rl_joint" gear="0.1250" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="motor_fl" joint="wheel_fl_joint" gear="0.1250" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="motor_rr" joint="wheel_rr_joint" gear="0.1250" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="motor_fr" joint="wheel_fr_joint" gear="0.1250" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>

  <sensor>
    <gyro name="imu_gyro" site="imu"/>
    <accelerometer name="imu_accel" site="imu"/>
    <framequat name="trunk_quat" objtype="site" objname="imu"/>
    <framepos name="trunk_pos" objtype="site" objname="imu"/>
    <framelinvel name="trunk_linvel" objtype="site" objname="imu"/>
    <jointvel name="enc_rl_vel" joint="wheel_rl_joint"/>
    <jointvel name="enc_rr_vel" joint="wheel_rr_joint"/>
    <jointpos name="enc_rl_pos" joint="wheel_rl_joint"/>
    <jointpos name="enc_rr_pos" joint="wheel_rr_joint"/>
  </sensor>
</mujoco>
