# Copy to .env on each Pi. Do not commit the real .env file.

# --- LiteLLM client (Pi-V) ---
# Endpoint confirmed 2026-06-20. API key: mint a Johnny5-specific virtual key
# on the LiteLLM proxy (separate from Agentic OS's key, for usage isolation).
# Model: vision-capable model string not yet selected -- see INITIATING_PROMPT.md.
LITELLM_ENDPOINT=http://192.168.1.223:4000/v1
LITELLM_API_KEY=<key>
LITELLM_MODEL=<vision-model-name>
LITELLM_TIMEOUT=8.0

# --- MQTT broker (both Pis) ---
MQTT_BROKER_HOST=<home-lab-ip>
MQTT_BROKER_PORT=1883
MQTT_USERNAME=<set-on-broker-deploy>
MQTT_PASSWORD=<set-on-broker-deploy>
