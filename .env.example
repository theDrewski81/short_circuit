# Copy to .env on each Pi. Do not commit the real .env file.

# --- LiteLLM client (Pi-V) ---
# Confirmed 2026-06-22. Johnny5-specific virtual key minted on the AOS LiteLLM
# proxy (DB-backed key mgmt stood up for this). vision-batch = llava:7b on
# ms3 (CPU-only Ollama node), chosen so it doesn't contend with desktop GPU
# work. Expect 15-40s/image latency, longer on cold load -- timeout below is
# set accordingly, well above the 8.0s default that would abandon every call.
LITELLM_ENDPOINT=http://192.168.1.223:4000/v1
LITELLM_API_KEY=sk-ft-osuRqKu2Eldav3HgAVw
LITELLM_MODEL=vision-batch
LITELLM_TIMEOUT=60.0

# --- MQTT broker (both Pis) ---
# Mosquitto LXC sn-mosquitto on host ms1. Confirmed live 2026-06-20.
MQTT_BROKER_HOST=192.168.1.227
MQTT_BROKER_PORT=1883
MQTT_USERNAME=johnny5
MQTT_PASSWORD=<set-on-broker-deploy>
